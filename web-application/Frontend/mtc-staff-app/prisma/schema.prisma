// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

model Staff {
  id          String   @id @default(uuid())
  name        String
  role        String
  department  String
  status      String   @default("offline")
  phone       String?
  email       String?  @unique
  lineId      String?  @unique
  avatarBg    String?
  avatarColor String?
  avatarUrl   String?
  joinedDate  String?
  birthday    String?
  bio         String?
  address     String?
  skills      String[] // Prisma supports scalar lists for PostgreSQL
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
